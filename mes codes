import requests

# ⚠️ Mets ta clé API ici (ou mieux: variable d'env plus tard)
API_KEY = "YOUR_YOUTUBE_API_KEY"

BASE_URL = "https://www.googleapis.com/youtube/v3/search"


# ------------------ RECHERCHE VIDÉOS ------------------
def search_youtube(query, max_results=20):
    """
    Récupère des vidéos YouTube brutes (sans filtrage).
    """

    params = {
        "part": "snippet",
        "q": query,
        "type": "video",
        "maxResults": max_results,
        "key": API_KEY
    }

    response = requests.get(BASE_URL, params=params)

    if response.status_code != 200:
        return []

    data = response.json()

    videos = data.get("items", [])

    return videos


# ------------------ DÉTAIL VIDÉO ------------------
def get_video_details(video_id):
    """
    Récupère infos + commentaires (si besoin futur)
    """

    url = "https://www.googleapis.com/youtube/v3/videos"

    params = {
        "part": "snippet,statistics",
        "id": video_id,
        "key": API_KEY
    }

    response = requests.get(url, params=params)

    if response.status_code != 200:
        return None, []

    data = response.json()

    items = data.get("items", [])
    if not items:
        return None, []

    video = items[0]

    # commentaires (optionnel, peut être amélioré plus tard)
    comments = []

    return video, comments
    
    
    #score.py
    def compute_score(video):
    stats = video.get("statistics", {})

    try:
        likes = int(stats.get("likeCount", 0))
        views = int(stats.get("viewCount", 1))
    except:
        return 0

    if views == 0:
        return 0

    score = (likes / views) * 1000

    return min(int(score), 100)


    #analyzer.py 
    def analyze_history(history):
    total = len(history)

    last_search = history[-1]["date"] if total > 0 else None

    queries = [h["query"] for h in history]

    top_query = max(set(queries), key=queries.count) if queries else None

    return {
        "total_searches": total,
        "last_search": last_search,
        "top_query": top_query
    }
    
    
    #filter.py
    import re

EDUCATIONAL_KEYWORDS = [
    "apprendre", "learn", "tutoriel", "tutorial",
    "cours", "lesson", "débutant", "beginner",
    "introduction", "guide", "formation",
    "exercice", "practice", "basics", "base",
    "explication", "détaillé"
]


def normalize(text: str) -> str:
    text = text.lower()  # 🔥 clé du problème résolu ici
    return re.sub(r"[^a-z0-9àâçéèêëîïôûùüÿñæœ\s]", " ", text)


def is_educational(text: str) -> bool:
    text = normalize(text)  # sécurité supplémentaire

    return any(
        keyword.lower() in text
        for keyword in EDUCATIONAL_KEYWORDS
    )


def filter_videos(videos):
    filtered = []

    for v in videos:
        snippet = v.get("snippet", {})

        title = snippet.get("title", "")
        desc = snippet.get("description", "")

        text = normalize(title + " " + desc)

        if is_educational(text):
            v["relevant"] = True
            filtered.append(v)

    return filtered

