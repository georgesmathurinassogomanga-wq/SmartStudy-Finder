#mic-btn.listening {
    animation: pulseMic 1s infinite;
}

@keyframes pulseMic {
    0% { transform: scale(1); box-shadow: 0 0 0 rgba(56,189,248,0.4); }
    50% { transform: scale(1.2); box-shadow: 0 0 15px rgba(56,189,248,0.6); }
    100% { transform: scale(1); }
}
.results {
    animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
